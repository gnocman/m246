<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">loyalty_points_listing.loyalty_points_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>loyalty_points_columns</spinner>
        <deps>
            <dep>loyalty_points_listing.loyalty_points_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="loyalty_points_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">point_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>NamCong_Loyalty::view_customer_points</aclResource>
        <dataProvider class="NamCong\Loyalty\Ui\DataProvider\Points\ListingDataProvider"
                      name="loyalty_points_listing_data_source">
            <settings>
                <requestFieldName>point_id</requestFieldName>
                <primaryFieldName>point_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="loyalty_points_columns">
        <column name="point_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="customer_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Customer ID</label>
            </settings>
        </column>
        <column name="total_points">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Total Points</label>
            </settings>
        </column>
        <column name="level" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="NamCong\Loyalty\Model\Config\Source\Level"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Level</label>
            </settings>
        </column>
        <column name="updated_at">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Last Updated</label>
            </settings>
        </column>
    </columns>
</listing>
