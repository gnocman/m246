<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">

    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">loyalty_reward_listing.loyalty_reward_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/edit"/>
                <class>primary</class>
                <label translate="true">Add New Reward</label>
            </button>
        </buttons>
        <spinner>loyalty_reward_columns</spinner>
        <deps>
            <dep>loyalty_reward_listing.loyalty_reward_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="loyalty_reward_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">reward_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>NamCong_Loyalty::manage_rewards</aclResource>
        <dataProvider class="NamCong\Loyalty\Ui\DataProvider\Reward\ListingDataProvider"
                      name="loyalty_reward_listing_data_source">
            <settings>
                <requestFieldName>reward_id</requestFieldName>
                <primaryFieldName>reward_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="loyalty_reward_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>reward_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="reward_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Reward Name</label>
            </settings>
        </column>
        <column name="required_points">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Required Points</label>
            </settings>
        </column>
        <column name="reward_type" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="NamCong\Loyalty\Model\Config\Source\RewardType"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Reward Type</label>
            </settings>
        </column>
        <column name="reward_value">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Reward Value</label>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="NamCong\Loyalty\Ui\Component\Reward\Column\Actions">
            <settings>
                <indexField>reward_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
