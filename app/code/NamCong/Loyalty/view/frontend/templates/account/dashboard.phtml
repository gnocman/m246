<script>
document.addEventListener('DOMContentLoaded', function () {
    // Animate progress bar
    var fill = document.getElementById('loyalty-progress-fill');
    var pct  = document.getElementById('loyalty-progress-pct');
    if (fill) {
        var target = parseFloat(fill.dataset.target || 0);
        setTimeout(function () {
            fill.style.width = target + '%';
            if (pct) { pct.textContent = target.toFixed(1) + '%'; }
        }, 300);
    }

    // Animate points counter
    var counter = document.getElementById('loyalty-total-points');
    if (counter) {
        var endVal = parseInt(counter.textContent, 10);
        var duration = 1200;
        var startTime = null;
        function animateCounter(timestamp) {
            if (!startTime) startTime = timestamp;
            var progress = Math.min((timestamp - startTime) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 4); // ease-out-quart
            counter.textContent = Math.round(eased * endVal).toLocaleString();
            if (progress < 1) { requestAnimationFrame(animateCounter); }
        }
        requestAnimationFrame(animateCounter);
    }
});

function copyLoyaltyCode(code, element) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(code).then(function() {
            var originalText = element.textContent;
            element.textContent = 'Copied!';
            element.classList.add('loyalty-coupon--copied');
            setTimeout(function() {
                element.textContent = code;
                element.classList.remove('loyalty-coupon--copied');
            }, 2000);
        });
    } else {
        // Fallback
        var textArea = document.createElement("textarea");
        textArea.value = code;
        document.body.appendChild(textArea);
        textArea.select();
        try {
            document.execCommand('copy');
            element.textContent = 'Copied!';
            setTimeout(function() { element.textContent = code; }, 2000);
        } catch (err) {}
        document.body.removeChild(textArea);
    }
}
</script>
